# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit the real file.

# ── Shopify ──────────────────────────────────────────────────────────────────
# Your store domain (no https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API access token — from your Shopify custom app
# Required scopes: write_price_rules, write_discounts
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=rre_4bK3qXbT_NmsC5pLWC4Jk2kHnMKwnBXQc

# "From" address — must be a domain you've verified in Resend
# Can be plain email or "Name <email>" format
RESEND_FROM_EMAIL=Historia Rewards <rewards@explorehistoria.com>
